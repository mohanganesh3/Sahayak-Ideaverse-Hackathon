# ── Neo4j ────────────────────────────────────────────────────────────────────
NEO4J_PASSWORD=changeme
# NEO4J_URI and NEO4J_USER are set automatically by docker-compose.
# Override only if running outside Docker:
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j

# ── LLM / AI Keys ────────────────────────────────────────────────────────────
GROQ_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
SARVAM_API_KEY=

# ── Optional ──────────────────────────────────────────────────────────────────
GOOGLE_CLOUD_VISION_KEY=
OPENFDA_API_KEY=

# ── App Settings ─────────────────────────────────────────────────────────────
DEFAULT_LANGUAGE=en
LOG_LEVEL=info
APP_PORT=8000

# ── Data Directory (host path, relative to docker-compose.yml) ───────────────
# SAHAYAK_DATA_DIR=../sahayak-data
